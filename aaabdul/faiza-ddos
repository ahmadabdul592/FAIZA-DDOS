}')\n\n    return {\n        'Model'    : name,\n        'Accuracy' : round(acc,  4),\n        'Precision': round(prec, 4),\n        'Recall'   : round(rec,  4),\n        'F1-Score' : round(f1,   4),\n        'ROC-AUC'  : round(roc,  4) if roc is not None else 'N/A'\n    }\n\n\ny_pred_rf  = rf_best.predict(X_test_fs)\ny_proba_rf = rf_best.predict_proba(X_test_fs)\nmetrics_rf = evaluate_model('Random Forest', y_test, y_pred_rf, y_proba_rf)\n\n\ny_proba_lstm = lstm_model.predict(X_test_lstm)\ny_pred_lstm  = np.argmax(y_proba_lstm, axis=1)\nmetrics_lstm = evaluate_model('LSTM', y_test, y_pred_lstm, y_proba_lstm)\n\n\ny_proba_hybrid = hybrid_lstm.predict(X_test_hybrid)\ny_pred_hybrid  = np.argmax(y_proba_hybrid, axis=1)\nmetrics_hybrid = evaluate_model('Hybrid RF-LSTM', y_test, y_pred_hybrid, y_proba_hybrid)\n\nprint(' Predictions complete for all 3 models on held-out 30% test set.')","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"results_df = pd.DataFrame([metrics_rf, metrics_lstm, metrics_hybrid])\nresults_df.set_index('Model', inplace=True)\n\nprint('\\n' + '='*65)\nprint('         MODEL COMPARISON — HELD-OUT TEST SET (30%)')\nprint('='*65)\nprint(results_df.to_string())\nprint('='*65)\n\nbest_model_name = results_df['F1-Score'].idxmax()\nprint(f'\\n🏆 Best model by F1-Score: {best_model_name}')\n\nresults_df.style.highlight_max(axis=0, color='lightgreen', subset=[\n    'Accuracy', 'Precision', 'Recall', 'F1-Score'\n])","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"fig, axes = plt.subplots(1, 3, figsize=(20, 6))\nclass_names = le.classes_\n\nfor ax, (name, y_pred) in zip(axes, [\n    ('Random Forest',  y_pred_rf),\n    ('LSTM',           y_pred_lstm),\n    ('Hybrid RF-LSTM', y_pred_hybrid),\n]):\n    cm = confusion_matrix(y_test, y_pred)\n    sns.heatmap(\n        cm, annot=True, fmt='d', cmap='Blues',\n        xticklabels=class_names, yticklabels=class_names, ax=ax\n    )\n    ax.set_title(f'{name}\\nConfusion Matrix', fontsize=12)\n    ax.set_xlabel('Predicted')\n    ax.set_ylabel('Actual')\n    ax.tick_params(axis='x', rotation=45)\n\nplt.suptitle('Confusion Matrices — All Models (Test Set 30%)', fontsize=14, y=1.02)\nplt.tight_layout()\nplt.savefig('confusion_matrices.png', dpi=150, bbox_inches='tight')\nplt.show()\nprint('Saved: confusion_matrices.png')","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"from sklearn.preprocessing import label_binarize\n\nplt.figure(figsize=(9, 7))\nclasses = np.unique(y_test)\n\nfor name, y_prob in [\n    ('Random Forest',  y_proba_rf),\n    ('LSTM',           y_proba_lstm),\n    ('Hybrid RF-LSTM', y_proba_hybrid),\n]:\n    if N_CLASSES == 2:\n        prob_pos = y_prob[:, 1]\n        fpr, tpr, _ = roc_curve(y_test, prob_pos)\n        roc_auc_val = auc(fpr, tpr)\n        plt.plot(fpr, tpr, linewidth=2, label=f'{name} (AUC = {roc_auc_val:.4f})')\n    else:\n        # Macro-average one-vs-rest ROC for multiclass\n        y_test_bin = label_binarize(y_test, classes=classes)\n        # Only ravel if shapes match\n        if y_test_bin.shape[1] == y_prob.shape[1]:\n            fpr, tpr, _ = roc_curve(y_test_bin.ravel(), y_prob.ravel())\n            roc_auc_val = auc(fpr, tpr)\n            plt.plot(fpr, tpr, linewidth=2, label=f'{name} (macro AUC = {roc_auc_val:.4f})')\n        else:\n            print(f'  Skipping ROC for {name} — class count mismatch.')\n\nplt.plot([0, 1], [0, 1], 'k--', linewidth=1, label='Random Classifier')\nplt.xlabel('False Positive Rate')\nplt.ylabel('True Positive Rate')\nplt.title('ROC Curves — RF vs LSTM vs Hybrid RF-LSTM')\nplt.legend(loc='lower right')\nplt.tight_layout()\nplt.savefig('roc_curves.png', dpi=150)\nplt.show()\nprint(' Saved: roc_curves.png')","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"for name, y_pred in [\n    ('Random Forest',  y_pred_rf),\n    ('LSTM',         